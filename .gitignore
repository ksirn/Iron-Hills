# ── LevelDB pack stores (generated by Foundry runtime) ─────────
# Foundry v12 хранит compendium-паки как LevelDB-папки.
# Сами .ldb/.log/MANIFEST/CURRENT/LOCK — рантайм-артефакты, нечего коммитить.
packs/**/*.ldb
packs/**/*.log
packs/**/*.log.old
packs/**/MANIFEST-*
packs/**/CURRENT
packs/**/LOCK
packs/**/LOG
packs/**/LOG.old

# Старые файловые БД из v11 и ниже
packs/*.db

# ── IDE / OS ───────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Node / build leftovers ─────────────────────────────────────
node_modules/
dist/
.cache/

# ── Logs / temp ─────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.tmp/
