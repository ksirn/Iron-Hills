<form class="iron-hills-sheet ih-char-sheet">

  {{!-- ШАПКА --}}
  <div class="ih-cs-header">
    <div class="ih-cs-portrait-wrap">
      <img class="ih-cs-portrait" src="{{actor.img}}" alt="{{actor.name}}">
      <div class="ih-cs-effects">
        {{#if system.conditions.bleeding}}<span class="ih-cs-fx" style="color:var(--ih-hp-crit)" title="Кровотечение: {{system.conditions.bleeding}}"><i class="fas fa-droplet"></i></span>{{/if}}
        {{#if system.conditions.poison}}<span class="ih-cs-fx" style="color:var(--ih-food)" title="Яд: {{system.conditions.poison}}"><i class="fas fa-skull"></i></span>{{/if}}
        {{#if system.conditions.burning}}<span class="ih-cs-fx" style="color:var(--ih-hp-bad)" title="Горение: {{system.conditions.burning}}"><i class="fas fa-fire"></i></span>{{/if}}
        {{#if system.conditions.shock}}<span class="ih-cs-fx" style="color:var(--ih-mana)" title="Шок: {{system.conditions.shock}}"><i class="fas fa-bolt"></i></span>{{/if}}
        {{#if system.conditions.stunned}}<span class="ih-cs-fx" style="color:var(--ih-hp-warn)" title="Оглушение: {{system.conditions.stunned}}"><i class="fas fa-dizzy"></i></span>{{/if}}
      </div>
    </div>

    <div class="ih-cs-identity">
      <input class="ih-cs-name" type="text" name="name" value="{{actor.name}}">
      <div class="ih-cs-meta-row">
        <div class="ih-cs-meta-field">
          <label>Раса</label>
          <input type="text" name="system.info.race" value="{{system.info.race}}" placeholder="—">
        </div>
        <div class="ih-cs-meta-field narrow-age">
          <label>Возраст</label>
          <input type="number" name="system.info.age" value="{{system.info.age}}">
        </div>
        <div class="ih-cs-meta-field">
          <label>Фракция</label>
          <input type="text" name="system.info.faction" value="{{system.info.faction}}" placeholder="—">
        </div>
        <div class="ih-cs-meta-field narrow">
          <label>Ступень</label>
          <span class="ih-cs-meta-value" title="Рассчитывается от максимального навыка">{{calculatedTier}}</span>
        </div>
      </div>
    </div>

    <div class="ih-cs-coins-block">
      <div class="ih-cs-coins-title">Монеты</div>
      <div class="ih-cs-coin-row"><span class="ih-cs-coin-label" style="color:#cd7f32">Медь</span><input type="number" name="system.currency.copper" value="{{system.currency.copper}}" min="0" class="ih-cs-coin-input"></div>
      <div class="ih-cs-coin-row"><span class="ih-cs-coin-label" style="color:#a8b8d0">Серебро</span><input type="number" name="system.currency.silver" value="{{system.currency.silver}}" min="0" class="ih-cs-coin-input"></div>
      <div class="ih-cs-coin-row"><span class="ih-cs-coin-label" style="color:var(--ih-hp-warn)">Золото</span><input type="number" name="system.currency.gold" value="{{system.currency.gold}}" min="0" class="ih-cs-coin-input"></div>
      <div class="ih-cs-coin-row"><span class="ih-cs-coin-label" style="color:var(--ih-mana)">Платина</span><input type="number" name="system.currency.platinum" value="{{system.currency.platinum}}" min="0" class="ih-cs-coin-input"></div>
    </div>
  </div>

  {{!-- ТЕЛО --}}
  <div class="ih-cs-body">

    {{!-- ЛЕВАЯ: тело + ресурсы + душа --}}
    <div class="ih-cs-left">

      <div class="ih-cs-section">
        <div class="ih-cs-section-title">Тело</div>
        <div class="ih-cs-body-layout">

          {{!-- Силуэт человечка --}}
          <div class="ih-cs-figure">
            {{#each zones}}{{#if (eq key "head")}}
            <div class="ih-cs-fig-part ih-cs-fig-head {{cssClass}}" title="{{tooltip}}">
              <div class="ih-cs-fig-fill" style="height:{{pct}}%"></div>
              <span class="ih-cs-fig-label">Г</span>
              {{#if trauma.majorBleeding}}<span class="ih-fig-dot dot-major"></span>{{/if}}
              {{#if trauma.minorBleeding}}<span class="ih-fig-dot dot-minor"></span>{{/if}}
              {{#if trauma.destroyed}}<span class="ih-fig-dot dot-destroyed"></span>{{/if}}
            </div>
            {{/if}}{{/each}}
            <div class="ih-cs-fig-row">
              {{#each zones}}{{#if (eq key "leftArm")}}
              <div class="ih-cs-fig-part ih-cs-fig-arm {{cssClass}}" title="{{tooltip}}">
                <div class="ih-cs-fig-fill" style="height:{{pct}}%"></div>
                <span class="ih-cs-fig-label">Л</span>
                {{#if trauma.fracture}}<span class="ih-fig-dot dot-fracture"></span>{{/if}}
                {{#if trauma.majorBleeding}}<span class="ih-fig-dot dot-major"></span>{{/if}}
                {{#if trauma.destroyed}}<span class="ih-fig-dot dot-destroyed"></span>{{/if}}
              </div>
              {{/if}}{{/each}}
              {{#each zones}}{{#if (eq key "torso")}}
              <div class="ih-cs-fig-part ih-cs-fig-torso {{cssClass}}" title="{{tooltip}}">
                <div class="ih-cs-fig-fill" style="height:{{pct}}%"></div>
                <span class="ih-cs-fig-label">Т</span>
                {{#if trauma.majorBleeding}}<span class="ih-fig-dot dot-major"></span>{{/if}}
                {{#if trauma.minorBleeding}}<span class="ih-fig-dot dot-minor"></span>{{/if}}
                {{#if trauma.destroyed}}<span class="ih-fig-dot dot-destroyed"></span>{{/if}}
              </div>
              {{/if}}{{/each}}
              {{#each zones}}{{#if (eq key "rightArm")}}
              <div class="ih-cs-fig-part ih-cs-fig-arm {{cssClass}}" title="{{tooltip}}">
                <div class="ih-cs-fig-fill" style="height:{{pct}}%"></div>
                <span class="ih-cs-fig-label">П</span>
                {{#if trauma.fracture}}<span class="ih-fig-dot dot-fracture"></span>{{/if}}
                {{#if trauma.majorBleeding}}<span class="ih-fig-dot dot-major"></span>{{/if}}
                {{#if trauma.destroyed}}<span class="ih-fig-dot dot-destroyed"></span>{{/if}}
              </div>
              {{/if}}{{/each}}
            </div>
            {{#each zones}}{{#if (eq key "abdomen")}}
            <div class="ih-cs-fig-part ih-cs-fig-abdomen {{cssClass}}" title="{{tooltip}}">
              <div class="ih-cs-fig-fill" style="height:{{pct}}%"></div>
              <span class="ih-cs-fig-label">Ж</span>
              {{#if trauma.majorBleeding}}<span class="ih-fig-dot dot-major"></span>{{/if}}
              {{#if trauma.destroyed}}<span class="ih-fig-dot dot-destroyed"></span>{{/if}}
            </div>
            {{/if}}{{/each}}
            <div class="ih-cs-fig-row">
              {{#each zones}}{{#if (eq key "leftLeg")}}
              <div class="ih-cs-fig-part ih-cs-fig-leg {{cssClass}}" title="{{tooltip}}">
                <div class="ih-cs-fig-fill" style="height:{{pct}}%"></div>
                <span class="ih-cs-fig-label">Л</span>
                {{#if trauma.fracture}}<span class="ih-fig-dot dot-fracture"></span>{{/if}}
                {{#if trauma.destroyed}}<span class="ih-fig-dot dot-destroyed"></span>{{/if}}
              </div>
              {{/if}}{{/each}}
              <div class="ih-cs-fig-gap"></div>
              {{#each zones}}{{#if (eq key "rightLeg")}}
              <div class="ih-cs-fig-part ih-cs-fig-leg {{cssClass}}" title="{{tooltip}}">
                <div class="ih-cs-fig-fill" style="height:{{pct}}%"></div>
                <span class="ih-cs-fig-label">П</span>
                {{#if trauma.fracture}}<span class="ih-fig-dot dot-fracture"></span>{{/if}}
                {{#if trauma.destroyed}}<span class="ih-fig-dot dot-destroyed"></span>{{/if}}
              </div>
              {{/if}}{{/each}}
            </div>
          </div>{{!-- .ih-cs-figure --}}

          {{!-- HP поля рядом с силуэтом --}}
          <div class="ih-cs-hp-list">
            {{#each zones}}
            <div class="ih-cs-hp-row {{cssClass}}" title="{{tooltip}}">
              <span class="ih-cs-hp-label">{{label}}</span>
              <input type="number" name="system.resources.hp.{{key}}.value"
                     value="{{value}}" class="ih-cs-hp-input">
              <span class="ih-cs-hp-max">/{{max}}</span>
              <div class="ih-cs-hp-bar-track">
                <div class="ih-cs-hp-bar-fill" style="width:{{pct}}%"></div>
              </div>
              <div class="ih-cs-zone-dots">
                {{#if trauma.majorBleeding}}<span class="ih-fig-dot dot-major" title="Сильн. кровь {{trauma.majorBleeding}}"></span>{{/if}}
                {{#if trauma.minorBleeding}}<span class="ih-fig-dot dot-minor" title="Кровь {{trauma.minorBleeding}}"></span>{{/if}}
                {{#if trauma.fracture}}<span class="ih-fig-dot dot-fracture" title="Перелом"></span>{{/if}}
                {{#if trauma.tourniquet}}<span class="ih-fig-dot dot-tourniquet" title="Жгут"></span>{{/if}}
                {{#if trauma.destroyed}}<span class="ih-fig-dot dot-destroyed" title="Уничтожено"></span>{{/if}}
              </div>
            </div>
            {{/each}}
          </div>

        </div>
      </div>

      <div class="ih-cs-section">
        <div class="ih-cs-section-title">Ресурсы</div>
        <div class="ih-cs-resources">
          <div class="ih-cs-res-row">
            <span class="ih-cs-res-icon energy">⚡</span>
            <span class="ih-cs-res-name">Энергия</span>
            <div class="ih-cs-res-vals">
              <input type="number" name="system.resources.energy.value" value="{{system.resources.energy.value}}" class="ih-cs-res-input">
              <span class="ih-cs-res-max">/{{system.resources.energy.max}}</span>
            </div>
            <div class="ih-cs-res-track"><div class="ih-cs-res-fill energy" style="width:{{overviewSummary.energyPct}}%"></div></div>
          </div>
          <div class="ih-cs-res-row">
            <span class="ih-cs-res-icon mana">✦</span>
            <span class="ih-cs-res-name">Мана</span>
            <div class="ih-cs-res-vals">
              <input type="number" name="system.resources.mana.value" value="{{system.resources.mana.value}}" class="ih-cs-res-input">
              <span class="ih-cs-res-max">/{{system.resources.mana.max}}</span>
            </div>
            <div class="ih-cs-res-track"><div class="ih-cs-res-fill mana" style="width:{{overviewSummary.manaPct}}%"></div></div>
          </div>
          <div class="ih-cs-res-row">
            <span class="ih-cs-res-icon food">🍖</span>
            <span class="ih-cs-res-name">Сытость</span>
            <div class="ih-cs-res-vals">
              <input type="number" name="system.resources.satiety.value" value="{{system.resources.satiety.value}}" class="ih-cs-res-input">
              <span class="ih-cs-res-max">/{{system.resources.satiety.max}}</span>
            </div>
            <div class="ih-cs-res-track"><div class="ih-cs-res-fill food" style="width:{{overviewSummary.satietyPct}}%"></div></div>
          </div>
          <div class="ih-cs-res-row">
            <span class="ih-cs-res-icon water">💧</span>
            <span class="ih-cs-res-name">Жажда</span>
            <div class="ih-cs-res-vals">
              <input type="number" name="system.resources.hydration.value" value="{{system.resources.hydration.value}}" class="ih-cs-res-input">
              <span class="ih-cs-res-max">/{{system.resources.hydration.max}}</span>
            </div>
            <div class="ih-cs-res-track"><div class="ih-cs-res-fill water" style="width:{{overviewSummary.hydrationPct}}%"></div></div>
          </div>
          <div class="ih-cs-res-row">
            <span class="ih-cs-res-icon" style="color:var(--ih-text-2)">⚖</span>
            <span class="ih-cs-res-name">Нагрузка</span>
            <span class="ih-cs-res-static">{{overviewSummary.weightValue}}/{{overviewSummary.weightMax}}</span>
            <div class="ih-cs-res-track"><div class="ih-cs-res-fill" style="width:{{overviewSummary.weightPct}}%;background:var(--ih-text-2)"></div></div>
          </div>
        </div>
      </div>

      {{!-- Болезни --}}
      {{#if diseases.length}}
      <div class="ih-cs-section">
        <div class="ih-cs-section-title">
          Болезни
          {{#if isGM}}<a class="ih-cs-section-action" data-add-disease title="Заразить">+ Добавить</a>{{/if}}
        </div>
        <div class="ih-cs-diseases">
          {{#each diseases}}
          <div class="ih-cs-disease stage-{{currentStage}}">
            <span class="ih-cs-disease-icon">{{icon}}</span>
            <div class="ih-cs-disease-info">
              <span class="ih-cs-disease-name">{{label}}</span>
              <span class="ih-cs-disease-stage">{{stageName}}</span>
              <div class="ih-cs-disease-bar">
                <div class="ih-cs-disease-bar-fill" style="width:{{progressPct}}%"></div>
              </div>
            </div>
            {{#if ../isGM}}
            <a class="ih-icon-btn" data-cure-disease="{{key}}" title="Вылечить">✕</a>
            {{/if}}
          </div>
          {{/each}}
        </div>
      </div>
      {{else if isGM}}
      <div class="ih-cs-section">
        <div class="ih-cs-section-title">
          Болезни
          <a class="ih-cs-section-action" data-add-disease title="Заразить">+ Добавить</a>
        </div>
        <div class="ih-cs-no-diseases muted-text">Здоров</div>
      </div>
      {{/if}}

      <div class="ih-cs-section">
        <div class="ih-cs-section-title">Резерв души</div>
        <div class="ih-cs-soul-grid">
          <div class="ih-cs-soul-item">
            <span class="ih-cs-soul-label" style="color:var(--ih-energy)">Энергия</span>
            <div class="ih-cs-soul-val">{{system.resources.soul.energyReserve.value}} / {{system.resources.soul.energyReserve.max}}</div>
          </div>
          <div class="ih-cs-soul-item">
            <span class="ih-cs-soul-label" style="color:var(--ih-mana)">Мана</span>
            <div class="ih-cs-soul-val">{{system.resources.soul.manaReserve.value}} / {{system.resources.soul.manaReserve.max}}</div>
          </div>
          {{#if system.resources.soulReserve.isDead}}
          <div class="ih-cs-soul-warning">☠ Мёртв — день {{system.resources.soulReserve.daysSinceDeath}}</div>
          {{/if}}
        </div>
      </div>

    {{!-- Болезни --}}
    {{#if activeDiseases.length}}
    <div class="ih-cs-section">
      <div class="ih-cs-section-title">Болезни</div>
      <div class="ih-cs-diseases">
        {{#each activeDiseases}}
        <div class="ih-cs-disease">
          <span class="ih-cs-disease-icon">{{icon}}</span>
          <div class="ih-cs-disease-info">
            <span class="ih-cs-disease-name">{{label}}</span>
            <span class="ih-cs-disease-stage">{{stageLabel}} · {{duration}}ч</span>
          </div>
          {{#if ../isGM}}
          <a class="ih-icon-btn" data-cure-disease="{{key}}" title="Вылечить">✕</a>
          {{/if}}
        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}

    </div>

    {{!-- ПРАВАЯ: навыки + инвентарь --}}
    <div class="ih-cs-right">

      <div class="ih-cs-section">
        <div class="ih-cs-section-title">Навыки</div>
        <div class="ih-cs-skills">
          {{#each skillGroups}}
          <div class="ih-cs-skill-group">
            <div class="ih-cs-skill-group-title">{{label}}</div>
            {{#each skills}}
            <div class="ih-cs-skill-row"
                 data-skill-roll="{{key}}" data-label="{{label}}"
                 style="cursor:pointer;" title="Кликни для броска">
              <span class="ih-cs-skill-name">{{label}}</span>
              <span class="ih-cs-skill-die">d{{dieSize}}</span>
              <div class="ih-cs-skill-exp-track" title="{{exp}} / {{expNext}}">
                <div class="ih-cs-skill-exp-fill" style="width:{{expPct}}%"></div>
              </div>
              <span class="ih-cs-skill-tier">{{value}}</span>
            </div>
            {{/each}}
          </div>
          {{/each}}
        </div>
      </div>

      {{!-- Репутация --}}
      {{#if (or settlementRelations.length factionRelations.length)}}
      <div class="ih-cs-section">
        <div class="ih-cs-section-title">
          Репутация
          {{#if isGM}}<a class="ih-cs-section-action" data-add-relation>+ Добавить</a>{{/if}}
        </div>
        <div class="ih-cs-relations">
          {{#each factionRelations}}
          <div class="ih-cs-relation" title="{{targetName}}">
            <div class="ih-cs-rel-bar-wrap">
              <span class="ih-cs-rel-name">{{targetName}}</span>
              <div class="ih-cs-rel-bar">
                <div class="ih-cs-rel-fill {{#if (gt score 0)}}positive{{else if (lt score 0)}}negative{{/if}}"
                     style="width:{{relPct}}%; {{#if (gt score 0)}}margin-left:50%{{else}}margin-left:{{relLeft}}%;{{/if}}"></div>
                <div class="ih-cs-rel-center"></div>
              </div>
              <span class="ih-cs-rel-score {{#if (gt score 0)}}text-good{{else if (lt score 0)}}text-bad{{/if}}">{{score}}</span>
            </div>
            <div class="ih-cs-rel-tier muted-text">{{tier}}</div>
            {{#if ../isGM}}
            <div class="ih-cs-rel-actions">
              <a class="ih-icon-btn" data-rel-change="10"  data-rel-id="{{id}}" title="+10">▲</a>
              <a class="ih-icon-btn" data-rel-change="-10" data-rel-id="{{id}}" title="-10">▼</a>
            </div>
            {{/if}}
          </div>
          {{/each}}
          {{#each settlementRelations}}
          <div class="ih-cs-relation settlement">
            <div class="ih-cs-rel-bar-wrap">
              <span class="ih-cs-rel-name">{{targetName}}</span>
              <div class="ih-cs-rel-bar">
                <div class="ih-cs-rel-fill {{#if (gt score 0)}}positive{{else if (lt score 0)}}negative{{/if}}"
                     style="width:{{relPct}}%;"></div>
                <div class="ih-cs-rel-center"></div>
              </div>
              <span class="ih-cs-rel-score">{{score}}</span>
            </div>
            {{#if ../isGM}}
            <div class="ih-cs-rel-actions">
              <a class="ih-icon-btn" data-rel-change="10"  data-rel-id="{{id}}" title="+10">▲</a>
              <a class="ih-icon-btn" data-rel-change="-10" data-rel-id="{{id}}" title="-10">▼</a>
            </div>
            {{/if}}
          </div>
          {{/each}}
        </div>
      </div>
      {{/if}}

      <div class="ih-cs-section">
        <div class="ih-cs-section-title">
          Инвентарь
          <span class="ih-cs-section-meta">{{overviewSummary.weightValue}}/{{overviewSummary.weightMax}} кг</span>
        </div>
        <div class="ih-cs-inventory">
          {{#each groupedItems}}
          {{#if items.length}}
          <div class="ih-cs-inv-group">
            <div class="ih-cs-inv-group-title">{{label}}</div>
            {{#each items}}
            <div class="ih-cs-inv-row">
              <img class="ih-cs-inv-icon" src="{{img}}" alt="{{name}}">
              <span class="ih-cs-inv-name">{{name}}</span>
              {{#if system.quantity}}<span class="ih-cs-inv-qty">×{{system.quantity}}</span>{{/if}}
              {{#if system.durability}}
              <div class="ih-cs-inv-dur-track" title="Прочность: {{system.durability.value}}/{{system.durability.max}}">
                <div class="ih-cs-inv-dur-fill {{#if (lt system.durability.value 25)}}is-crit{{else if (lt system.durability.value 50)}}is-warn{{/if}}"
                     style="width:{{durabilityPct}}%"></div>
              </div>
              {{/if}}
              <span class="ih-cs-inv-weight muted-text">{{system.weight}}кг</span>
              <div class="ih-cs-inv-actions">
                {{#if system.durability}}<a class="ih-icon-btn" data-item-repair data-item-id="{{id}}" title="Починить">🔨</a>{{/if}}
                <a class="ih-icon-btn" data-item-edit data-item-id="{{id}}" title="Редактировать">✎</a>
                <a class="ih-icon-btn" data-item-delete data-item-id="{{id}}" title="Удалить">✕</a>
              </div>
            </div>
            {{/each}}
          </div>
          {{/if}}
          {{/each}}
        </div>
      </div>

    </div>

  </div>

</form>
