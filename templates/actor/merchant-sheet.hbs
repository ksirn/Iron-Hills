<form class="iron-hills-sheet">
  <header class="sheet-header">
    <div class="hero-header">
      <div>
        <h1>{{actor.name}}</h1>
        <div class="hero-subline">
          <span>Специализация: {{tradeSummary.specialty}}</span>
          <span>Поселение: {{tradeSummary.settlement}}</span>
          <span>Фракция: {{tradeSummary.faction}}</span>
        </div>
      </div>
      <div class="hero-states">
        <span class="state-pill">Богатство: {{tradeSummary.wealth}}</span>
        <span class="state-pill">Наценка: x{{tradeSummary.markup}}</span>
        <span class="state-pill">Репутация игрока: {{tradeModifiers.relationScore}}</span>
        <span class="state-pill">Торгует: {{activeTradeCharacterName}}</span>
      </div>
    </div>
  </header>

  <nav class="sheet-tabs tabs">
    <a class="item active" data-tab="overview">Обзор</a>
  </nav>

  <section class="sheet-body">
    <div class="tab active" data-tab="overview">
        <div class="status-card">
        <h2>Торговля</h2>
        <p>Для торговли используй отдельное окно.</p>
        <div class="inventory-actions">
          <a data-open-trade-app>Открыть окно торговли</a>
        </div>
      </div>
      {{#unless hasActiveTradeCharacter}}
        <div class="status-card">
          <h2>Торговля недоступна</h2>
          <p>Не найден активный персонаж для торговли.</p>
          <p>Выбери персонажа вручную в блоке торговли или назначь User Character</p>
        </div>
      {{/unless}}
      <div class="hero-stats-grid">
        <div class="hero-stat-card">
          <div class="hero-stat-title">Богатство</div>
          <div class="hero-stat-value">{{tradeSummary.wealth}}</div>
        </div>
        <div class="hero-stat-card">
          <div class="hero-stat-title">Наценка</div>
          <div class="hero-stat-value">x{{tradeSummary.markup}}</div>
        </div>
        <div class="hero-stat-card">
          <div class="hero-stat-title">Репутация</div>
          <div class="hero-stat-value">{{tradeModifiers.relationScore}}</div>
        </div>
        <div class="hero-stat-card">
          <div class="hero-stat-title">Модификатор покупки</div>
          <div class="hero-stat-value">x{{tradeModifiers.buyModifier}}</div>
        </div>
        <div class="hero-stat-card">
          <div class="hero-stat-title">Модификатор продажи</div>
          <div class="hero-stat-value">x{{tradeModifiers.sellModifier}}</div>
        </div>
        <div class="hero-stat-card">
          <div class="hero-stat-title">Благополучие</div>
          <div class="hero-stat-value">{{tradeSummary.settlementProsperity}}</div>
        </div>
        <div class="hero-stat-card">
          <div class="hero-stat-title">Снабжение</div>
          <div class="hero-stat-value">{{tradeSummary.settlementSupply}}</div>
        </div>
        <div class="hero-stat-card">
          <div class="hero-stat-title">Опасность</div>
          <div class="hero-stat-value">{{tradeSummary.settlementDanger}}</div>
        </div>
      </div>

      <div class="status-grid">
        <div class="status-card">
          <h2>Основные данные</h2>
          <div class="grid two-col">
            <label>Специализация
              <input type="text" name="system.info.specialty" value="{{system.info.specialty}}">
            </label>
            <label>Поселение
              <input type="text" name="system.info.settlement" value="{{system.info.settlement}}">
            </label>
            <label>Фракция
              <input type="text" name="system.info.faction" value="{{system.info.faction}}">
            </label>
            <label>Богатство
              <input type="number" name="system.economy.wealth" value="{{system.economy.wealth}}">
            </label>
            <label>Наценка
              <input type="number" step="0.01" name="system.economy.markup" value="{{system.economy.markup}}">
            </label>
            <label>Экономика поселения
              <input type="text" value="Благополучие {{tradeSummary.settlementProsperity}} / Снабжение {{tradeSummary.settlementSupply}} / Опасность {{tradeSummary.settlementDanger}}" disabled>
            </label>
          </div>
        </div>

        <div class="status-card">
          <h2>Торговая логика</h2>
          <p>Цена покупки игроком зависит от:</p>
          <p>- базовой цены предмета</p>
          <p>- наценки торговца</p>
          <p>- репутации с фракцией или поселением торговца</p>
          <br>
          <p>Цена выкупа у игрока считается отдельно и обычно ниже базовой.</p>
        </div>
      </div>
    </div>
  </section>
</form>