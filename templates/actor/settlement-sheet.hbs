<form class="iron-hills-sheet">
  <header class="sheet-header">
    <h1>{{actor.name}}</h1>
  </header>

  <section class="sheet-body">
    <h2>Параметры поселения</h2>
    <div class="grid two-col">
      <label>Регион
        <input type="text" name="system.info.region" value="{{system.info.region}}">
      </label>
      <label>Тир
        <input type="number" name="system.info.tier" value="{{system.info.tier}}">
      </label>
      <label>Население
        <input type="number" name="system.info.population" value="{{system.info.population}}">
      </label>
      <label>Благополучие
        <input type="number" name="system.info.prosperity" value="{{system.info.prosperity}}">
      </label>
      <label>Опасность
        <input type="number" name="system.info.danger" value="{{system.info.danger}}">
      </label>
      <label>Снабжение
        <input type="number" name="system.info.supply" value="{{system.info.supply}}">
      </label>
      <label>Контролирующая фракция
        <input type="text" name="system.info.controllingFaction" value="{{system.info.controllingFaction}}">
      </label>
      <label>Теги
        <input type="text" name="system.info.tags" value="{{system.info.tags}}">
      </label>
    </div>

    <h2>Экономика поселения</h2>
    <div class="grid two-col">
      <label>Цена еды
        <input type="number" step="0.01" name="system.economy.foodPrice" value="{{system.economy.foodPrice}}">
      </label>
      <label>Цена материалов
        <input type="number" step="0.01" name="system.economy.materialsPrice" value="{{system.economy.materialsPrice}}">
      </label>
      <label>Цена алхимии
        <input type="number" step="0.01" name="system.economy.alchemyPrice" value="{{system.economy.alchemyPrice}}">
      </label>
      <label>Цена оружия
        <input type="number" step="0.01" name="system.economy.armsPrice" value="{{system.economy.armsPrice}}">
      </label>
      <label>Цена ночлега
        <input type="number" step="0.01" name="system.economy.lodgingPrice" value="{{system.economy.lodgingPrice}}">
      </label>
      <label>Давление фракции
        <input type="number" name="system.economy.factionPressure" value="{{system.economy.factionPressure}}">
      </label>
      <label>Торговцев
        <input type="number" name="system.economy.merchantCount" value="{{system.economy.merchantCount}}">
      </label>
      <label>Пути
        <input type="number" name="system.economy.routeValue" value="{{system.economy.routeValue}}">
      </label>
    </div>

    <h2>Региональная симуляция</h2>
    <div class="grid two-col">
      <label>Активный кризис
        <input type="text" name="system.regionSim.activeCrisis" value="{{system.regionSim.activeCrisis}}">
      </label>
      <label>Торговый баланс
        <input type="number" name="system.regionSim.tradeBalance" value="{{system.regionSim.tradeBalance}}">
      </label>
      <label>Трафик караванов
        <input type="number" name="system.regionSim.caravanTraffic" value="{{system.regionSim.caravanTraffic}}">
      </label>
      <label>Последний караван
        <input type="text" name="system.regionSim.lastCaravan" value="{{system.regionSim.lastCaravan}}">
      </label>
      <label>Последнее региональное событие
        <input type="text" name="system.regionSim.lastRegionEvent" value="{{system.regionSim.lastRegionEvent}}">
      </label>
      <label>Стабильность
        <input type="number" name="system.regionSim.stability" value="{{system.regionSim.stability}}">
      </label>
      <label>Сила милиции
        <input type="number" name="system.regionSim.militiaPower" value="{{system.regionSim.militiaPower}}">
      </label>
    </div>

    <h2>Сводка недели</h2>
    <div class="status-card">
      <p>{{system.economy.weeklySummary}}</p>
    </div>

    <div class="status-grid">
      <div class="status-card">
        <h3>Последние события</h3>
        {{#each system.history.events}}
          <p>{{this}}</p>
        {{/each}}
      </div>

      <div class="status-card">
        <h3>Последние слухи</h3>
        {{#each system.history.rumors}}
          <p>{{this}}</p>
        {{/each}}
      </div>
    </div>

    <div class="status-card">
      <h3>Региональные события</h3>
      {{#each system.history.regionalEvents}}
        <p>{{this}}</p>
      {{/each}}
    </div>
  </section>
</form>