{{!-- Iron Hills — Status Panel (compact, always on) --}}
<section class="ih-combat-hud is-compact {{actorSideClass}}">
{{#if hasActor}}

<div class="ih-hud-compact-layout">

  {{!-- Topbar: портрет + эффекты + имя + статус + toggle --}}
  <div class="ih-hud-topbar">

    {{!-- Портрет с иконками эффектов поверх --}}
    <div class="ih-hud-portrait-wrap {{actorSideClass}}">
      <img class="ih-hud-portrait-img" src="{{actorImg}}" alt="{{actorName}}">
      {{#if hasGlobalEffects}}
      <div class="ih-portrait-effects">
        {{#each globalEffects}}{{#if active}}
        <span class="ih-fx-icon" style="color:{{color}}" title="{{label}}: {{value}}">
          <i class="fas {{icon}}"></i>
        </span>
        {{/if}}{{/each}}
      </div>
      {{/if}}
    </div>

    <div class="ih-hud-topbar-info">
      <div class="ih-hud-name">{{actorName}}</div>
      {{#if combatActive}}
        {{#if isCurrentTurn}}
          <div class="ih-turn-chip is-active">⚔ {{secondsLeft}}с</div>
        {{else}}
          <div class="ih-turn-chip">↻ {{currentTurnName}}</div>
        {{/if}}
      {{else}}
        <div class="ih-turn-chip is-peace">✦ Мир</div>
      {{/if}}
    </div>

  </div>

  {{!-- Тело + ресурсы --}}
  <div class="ih-compact-body-row">

    {{!-- Силуэт человечка --}}
    <div class="ih-figure-wrap">
      {{!-- Голова --}}
      {{#each zones}}{{#if (eq key "head")}}
      <div class="ih-fig-part ih-fig-head {{cssClass}}" title="{{tooltip}}">
        <div class="ih-fig-fill" style="height:{{pct}}%"></div>
        <div class="ih-fig-dots">
          {{#if trauma.destroyed}}<span class="ih-fig-dot dot-destroyed"></span>{{/if}}
          {{#if trauma.majorBleeding}}<span class="ih-fig-dot dot-major"></span>{{/if}}
          {{#if trauma.minorBleeding}}<span class="ih-fig-dot dot-minor"></span>{{/if}}
          {{#if trauma.fracture}}<span class="ih-fig-dot dot-fracture"></span>{{/if}}
        </div>
      </div>
      {{/if}}{{/each}}

      {{!-- Руки + Торс --}}
      <div class="ih-fig-row">
        {{#each zones}}{{#if (eq key "leftArm")}}
        <div class="ih-fig-part ih-fig-arm {{cssClass}}" title="{{tooltip}}">
          <div class="ih-fig-fill" style="height:{{pct}}%"></div>
          <div class="ih-fig-dots">
            {{#if trauma.destroyed}}<span class="ih-fig-dot dot-destroyed"></span>{{/if}}
            {{#if trauma.majorBleeding}}<span class="ih-fig-dot dot-major"></span>{{/if}}
            {{#if trauma.fracture}}<span class="ih-fig-dot dot-fracture"></span>{{/if}}
          </div>
        </div>
        {{/if}}{{/each}}

        {{#each zones}}{{#if (eq key "torso")}}
        <div class="ih-fig-part ih-fig-torso {{cssClass}}" title="{{tooltip}}">
          <div class="ih-fig-fill" style="height:{{pct}}%"></div>
          <div class="ih-fig-dots">
            {{#if trauma.destroyed}}<span class="ih-fig-dot dot-destroyed"></span>{{/if}}
            {{#if trauma.majorBleeding}}<span class="ih-fig-dot dot-major"></span>{{/if}}
            {{#if trauma.minorBleeding}}<span class="ih-fig-dot dot-minor"></span>{{/if}}
          </div>
        </div>
        {{/if}}{{/each}}

        {{#each zones}}{{#if (eq key "rightArm")}}
        <div class="ih-fig-part ih-fig-arm {{cssClass}}" title="{{tooltip}}">
          <div class="ih-fig-fill" style="height:{{pct}}%"></div>
          <div class="ih-fig-dots">
            {{#if trauma.destroyed}}<span class="ih-fig-dot dot-destroyed"></span>{{/if}}
            {{#if trauma.majorBleeding}}<span class="ih-fig-dot dot-major"></span>{{/if}}
            {{#if trauma.fracture}}<span class="ih-fig-dot dot-fracture"></span>{{/if}}
          </div>
        </div>
        {{/if}}{{/each}}
      </div>

      {{!-- Живот --}}
      {{#each zones}}{{#if (eq key "abdomen")}}
      <div class="ih-fig-part ih-fig-abdomen {{cssClass}}" title="{{tooltip}}">
        <div class="ih-fig-fill" style="height:{{pct}}%"></div>
        <div class="ih-fig-dots">
          {{#if trauma.destroyed}}<span class="ih-fig-dot dot-destroyed"></span>{{/if}}
          {{#if trauma.majorBleeding}}<span class="ih-fig-dot dot-major"></span>{{/if}}
          {{#if trauma.minorBleeding}}<span class="ih-fig-dot dot-minor"></span>{{/if}}
        </div>
      </div>
      {{/if}}{{/each}}

      {{!-- Ноги --}}
      <div class="ih-fig-row">
        {{#each zones}}{{#if (eq key "leftLeg")}}
        <div class="ih-fig-part ih-fig-leg {{cssClass}}" title="{{tooltip}}">
          <div class="ih-fig-fill" style="height:{{pct}}%"></div>
          <div class="ih-fig-dots">
            {{#if trauma.destroyed}}<span class="ih-fig-dot dot-destroyed"></span>{{/if}}
            {{#if trauma.fracture}}<span class="ih-fig-dot dot-fracture"></span>{{/if}}
          </div>
        </div>
        {{/if}}{{/each}}
        <div class="ih-fig-gap"></div>
        {{#each zones}}{{#if (eq key "rightLeg")}}
        <div class="ih-fig-part ih-fig-leg {{cssClass}}" title="{{tooltip}}">
          <div class="ih-fig-fill" style="height:{{pct}}%"></div>
          <div class="ih-fig-dots">
            {{#if trauma.destroyed}}<span class="ih-fig-dot dot-destroyed"></span>{{/if}}
            {{#if trauma.fracture}}<span class="ih-fig-dot dot-fracture"></span>{{/if}}
          </div>
        </div>
        {{/if}}{{/each}}
      </div>
    </div>{{!-- .ih-figure-wrap --}}

    {{!-- Ресурс-бары + быстрые слоты --}}
    <div class="ih-compact-bars">
      <div class="ih-res-bar" title="Энергия: {{energyValue}}/{{energyMax}}">
        <span class="ih-res-icon energy">⚡</span>
        <div class="ih-res-track"><div class="ih-res-fill energy" style="width:{{energyPct}}%"></div></div>
        <span class="ih-res-val">{{energyValue}}</span>
      </div>
      <div class="ih-res-bar" title="Мана: {{manaValue}}/{{manaMax}}">
        <span class="ih-res-icon mana">✦</span>
        <div class="ih-res-track"><div class="ih-res-fill mana" style="width:{{manaPct}}%"></div></div>
        <span class="ih-res-val">{{manaValue}}</span>
      </div>
      <div class="ih-res-bar" title="Сытость: {{satietyValue}}/{{satietyMax}}">
        <span class="ih-res-icon food">🍖</span>
        <div class="ih-res-track"><div class="ih-res-fill food" style="width:{{satietyPct}}%"></div></div>
        <span class="ih-res-val">{{satietyValue}}</span>
      </div>
      <div class="ih-res-bar" title="Жажда: {{hydrationValue}}/{{hydrationMax}}">
        <span class="ih-res-icon water">💧</span>
        <div class="ih-res-track"><div class="ih-res-fill water" style="width:{{hydrationPct}}%"></div></div>
        <span class="ih-res-val">{{hydrationValue}}</span>
      </div>

      {{!-- Быстрые слоты --}}
      <div class="ih-compact-slots">
        {{#each quickSlots}}
        <a class="ih-quick-chip" data-quickslot="{{slotKey}}" title="[{{short}}] {{itemName}}">
          <span>{{short}}</span>
        </a>
        {{/each}}
      </div>
    </div>
  </div>{{!-- .ih-compact-body-row --}}

  {{!-- Pending action --}}
  {{#if hasPendingAction}}
  <div class="ih-pending-bar">
    <span class="ih-pending-label">⏳ {{pendingActionLabel}}</span>
    <span class="ih-pending-secs">{{pendingActionRemainingSeconds}}с</span>
    {{#if canContinuePendingAction}}<a class="ih-chip ih-chip-ok" data-continue-pending title="Продолжить">▶</a>{{/if}}
    {{#if canCancelPendingAction}}<a class="ih-chip ih-chip-danger" data-cancel-pending title="Отменить">✕</a>{{/if}}
  </div>
  {{/if}}

  {{!-- Action кнопки (только в бой/свой ход) --}}
  {{#if combatActive}}{{#if isCurrentTurn}}
  <div class="ih-compact-actions">
    <a class="ih-cact-btn" data-attack-hand="leftHand" title="{{leftHandName}}">⚔</a>
    {{#if rightHandEquipped}}
    <a class="ih-cact-btn" data-attack-hand="rightHand" title="{{rightHandName}}">🗡</a>
    {{/if}}
    {{#if hasMana}}
    <a class="ih-cact-btn" data-cast-spell title="Заклинания">✨</a>
    {{/if}}
    {{#if canBreathe}}
    <a class="ih-cact-btn" data-breathe title="Перевести дух">💨</a>
    {{/if}}
    <a class="ih-cact-btn ih-cact-sprint {{#if isSprinting}}is-active{{/if}}"
       data-toggle-sprint title="Шаг/Рывок">{{#if isSprinting}}🏃{{else}}🚶{{/if}}</a>
    {{#if canEndTurn}}
    <a class="ih-cact-btn ih-cact-end" data-end-turn title="Завершить ход">✓</a>
    {{/if}}
    {{#if isGM}}
    <a class="ih-cact-btn" data-next-turn title="Следующий">→</a>
    {{/if}}
  </div>
  {{/if}}{{/if}}

</div>{{!-- .ih-hud-compact-layout --}}


{{!-- ═══════════════════════════════════════════════════════
      EXPANDED MODE — Вариант Б
      Слева: портрет + большой силуэт + ресурсы
      Справа: статус хода + действия
══════════════════════════════════════════════════════════ --}}




{{!-- Очередь участников --}}
  {{#if combatActive}}
  <div class="ih-queue-strip">
    {{#each queue}}
    <div class="ih-queue-pill {{sideClass}} {{#if isCurrent}}is-current{{/if}}"
         title="{{name}} — {{secondsLeft}}с">
      <span class="ih-queue-name">{{name}}</span>
      <span class="ih-queue-secs">{{secondsLeft}}с</span>
    </div>
    {{/each}}
  </div>
  {{/if}}{{!-- combatActive --}}

{{else}}{{!-- hasActor --}}
<div class="ih-hud-empty">
  <div class="ih-hud-empty-icon">⚔</div>
  <div class="ih-hud-empty-hint">Нет персонажа</div>
</div>
{{/if}}{{!-- hasActor --}}
</section>
