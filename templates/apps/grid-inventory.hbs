{{!-- Iron Hills — Grid Inventory v4: одна страница --}}
<div class="ih-gi-app">

  {{!-- ── ЛЕВАЯ: экипировка ── --}}
  <div class="ih-gi-equip-panel">
    <div class="ih-gi-equip-title">Экипировка</div>
    <div class="ih-gi-silhouette">
      {{#each equipSlots}}
      <div class="ih-gi-equip-slot {{#if hasItem}}has-item ih-has-inv-tooltip{{/if}}"
           data-slot="{{key}}"
           draggable="{{#if hasItem}}true{{else}}false{{/if}}"
           style="left:{{x}}px; top:{{y}}px; width:{{w}}px; height:{{h}}px;">
        {{#if hasItem}}
          <img class="ih-gi-equip-img" src="{{itemImg}}" alt="{{itemName}}">
          {{#if durPct}}
          <div class="ih-gi-equip-dur">
            <div class="ih-gi-equip-dur-fill" style="width:{{durPct}}%"></div>
          </div>
          {{/if}}
          {{#if resist}}<span class="ih-gi-equip-resist">{{resist}}</span>{{/if}}
          {{!-- Tooltip для слота экипировки --}}
          <div class="ih-gi-tooltip">
            <div class="ih-gi-tooltip-header">
              <img src="{{itemImg}}" width="24" height="24">
              <div>
                <div class="ih-gi-tooltip-name">{{itemName}}</div>
                <div class="muted-text" style="font-size:9px">{{label}}</div>
              </div>
            </div>
            {{#if itemTooltipStats}}
            <div class="ih-gi-tooltip-stats">{{itemTooltipStats}}</div>
            {{/if}}
            {{#if durPct}}
            <div class="ih-gi-tooltip-dur {{durClass}}">
              🔧 {{durPct}}%
              {{#if (lt durPct 26)}}— Критический{{else if (lt durPct 51)}}— Повреждён{{else if (lt durPct 76)}}— Изношен{{else}}— Норма{{/if}}
            </div>
            {{/if}}
          </div>
        {{else}}
          <span class="ih-gi-slot-icon">{{icon}}</span>
          <span class="ih-gi-slot-label">{{label}}</span>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </div>

  {{!-- ── ПРАВАЯ: все секции вертикально ── --}}
  <div class="ih-gi-grid-panel">
    <div class="ih-gi-hint">
    ПКМ → надеть / переложить / на землю &nbsp;·&nbsp; 2×клик → надеть автоматически &nbsp;·&nbsp; ПКМ на слот → снять
  </div>

    <div class="ih-gi-all-sections">
      {{#each allSections}}
      <div class="ih-gi-sec-block {{#if isActive}}is-active{{/if}}"
           data-sec-key="{{key}}">

        {{!-- Заголовок секции --}}
        <div class="ih-gi-sec-header" data-sec-key="{{key}}">
          <span class="ih-gi-sec-icon">{{contIcon}}</span>
          <span class="ih-gi-sec-name">{{label}}</span>
          <span class="muted-text">{{cols}}×{{rows}}</span>
          {{#if accessSeconds}}
          <span class="ih-gi-access">⏱ {{accessSeconds}}с</span>
          {{else}}
          <span class="ih-gi-access fast">⚡</span>
          {{/if}}
          {{#if allowedLabel}}
          <span class="ih-gi-allowed">{{allowedLabel}}</span>
          {{/if}}
          {{#if overflow.length}}
          <span class="ih-gi-sec-overflow-badge">⚠ {{overflow.length}}</span>
          {{/if}}
        </div>

        {{!-- Сетка --}}
        <div class="ih-gi-canvas-wrap">
          <div class="ih-gi-canvas {{#if pocketMode}}pocket-mode{{/if}}"
               data-sec-key="{{key}}"
               style="width:{{gridW}}px; height:{{gridH}}px;">

            {{#each cells}}
            <div class="ih-gi-cell {{#if isPocket}}is-pocket{{/if}}"
                 data-col="{{col}}" data-row="{{row}}"
                 style="left:{{x}}px; top:{{y}}px; width:{{size}}px; height:{{size}}px;">
            </div>
            {{/each}}

            {{#each placed}}
            <div class="ih-gi-item {{#if isBroken}}is-broken{{/if}} {{#if rotated}}is-rotated{{/if}} {{#unless identified}}is-unknown{{/unless}} ih-has-inv-tooltip"
                 draggable="true"
                 data-item-id="{{itemId}}"
                 data-sec-key="{{../key}}"
                 style="left:{{cssLeft}}px; top:{{cssTop}}px;
                        width:{{cssW}}px; height:{{cssH}}px;">
              <img class="ih-gi-item-img" src="{{img}}" alt="{{name}}">
              {{#if (gt qty 1)}}<span class="ih-gi-qty">{{qty}}</span>{{/if}}
              <span class="ih-gi-tier">{{tier}}</span>
              {{#if rotated}}<span class="ih-gi-rotated-mark">↺</span>{{/if}}
              {{#if durPct}}
              <div class="ih-gi-dur-bar">
                <div class="ih-gi-dur-fill {{#if (lt durPct 25)}}is-crit{{else if (lt durPct 50)}}is-warn{{/if}}"
                     style="width:{{durPct}}%"></div>
              </div>
              {{/if}}
              {{!-- Tooltip --}}
              <div class="ih-gi-tooltip">
                <div class="ih-gi-tooltip-header">
                  <img src="{{img}}" width="24" height="24">
                  <div>
                    <div class="ih-gi-tooltip-name">{{visibleName}}</div>
                    <div class="muted-text" style="font-size:9px">Тир {{tier}}{{#if (gt qty 1)}} · ×{{qty}}{{/if}}</div>
                  </div>
                </div>
                {{#if tooltipStats}}
                <div class="ih-gi-tooltip-stats">{{tooltipStats}}</div>
                {{/if}}
                {{#if durPct}}
                <div class="ih-gi-tooltip-dur {{durClass}}">
                  🔧 {{durPct}}%
                  {{#if (lt durPct 26)}}— Критический{{else if (lt durPct 51)}}— Повреждён{{else if (lt durPct 76)}}— Изношен{{else}}— Норма{{/if}}
                </div>
                {{/if}}
                {{#unless identified}}
                <div style="color:#facc15;font-size:10px;margin-top:3px">❓ Не опознан</div>
                {{/unless}}
              </div>
            </div>
            {{/each}}

          </div>
        </div>

        {{!-- Overflow --}}
        {{#if overflow.length}}
        <div class="ih-gi-overflow-inline">
          {{#each overflow}}
          <div class="ih-gi-overflow-row">
            <img src="{{img}}" width="20" height="20">
            <span>{{name}}</span>
            <a class="ih-btn ih-btn-small" data-auto-place data-item-id="{{itemId}}">+</a>
          </div>
          {{/each}}
        </div>
        {{/if}}

      </div>{{!-- .ih-gi-sec-block --}}
      {{/each}}

      {{#unless allSections.length}}
      <div class="ih-gi-empty-cont">
        <div class="ih-gi-empty-icon">📦</div>
        <div>Нет контейнеров</div>
        <div class="muted-text">Надень ремень, рюкзак или броню с карманами</div>
      </div>
      {{/unless}}


      {{!-- Нераспределённые предметы --}}
      {{#if hasPending}}
      <div class="ih-gi-pending-zone">
        <div class="ih-gi-pending-header">
          📥 К распределению <span class="ih-gi-pending-count">{{pendingItems.length}}</span>
          <span class="muted-text" style="font-size:10px;font-weight:400">
            — перетащи в слот или нажми + для авторазмещения
          </span>
        </div>
        <div class="ih-gi-pending-list">
          {{#each pendingItems}}
          <div class="ih-gi-pending-item" draggable="true"
               data-pending-item-id="{{itemId}}">
            <img src="{{img}}" width="24" height="24"
                 style="border-radius:3px;object-fit:contain;background:#1a1f2e">
            <span class="ih-gi-pending-name">{{name}}</span>
            <span class="muted-text" style="font-size:10px">{{w}}×{{h}}</span>
            {{#if qty}}<span class="ih-gi-pending-qty">×{{qty}}</span>{{/if}}
            <a class="ih-btn ih-btn-small" data-auto-place data-item-id="{{itemId}}"
               title="Авторазместить">+</a>
            <a class="ih-btn ih-btn-small ih-btn-danger" data-drop-to-ground
               data-item-id="{{itemId}}" title="Выбросить">🪨</a>
          </div>
          {{/each}}
        </div>
        <div class="ih-gi-pending-actions">
          <a class="ih-btn ih-btn-primary" data-auto-place-all>✨ Разместить всё</a>
        </div>
      </div>
      {{/if}}

    </div>{{!-- .ih-gi-all-sections --}}
  </div>{{!-- .ih-gi-grid-panel --}}
</div>
