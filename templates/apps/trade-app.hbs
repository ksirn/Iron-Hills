{{!-- ============================================================
  IRON HILLS — Trade Window v2
  Двусторонний обмен: Игрок ↔ NPC (через GM)
  ============================================================ --}}

<div class="ih-trade-app">

  {{!-- ── ШАПКА ── --}}
  <div class="ih-trade-header">
    <div class="ih-trade-party">
      <div class="ih-trade-avatar">
        <img src="{{merchantImg}}" alt="{{merchantName}}">
        {{#if reputation}}
        <span class="ih-trade-rep {{#if reputationPositive}}is-good{{else}}is-bad{{/if}}"
              title="Репутация">{{reputation}}</span>
        {{/if}}
      </div>
      <div class="ih-trade-party-info">
        <div class="ih-trade-party-name">{{merchantName}}</div>
        <div class="ih-trade-party-meta">
          {{#if tradeSummary.specialty}}<span class="ih-trade-tag">{{tradeSummary.specialty}}</span>{{/if}}
          <span class="ih-trade-tag">Ст. {{merchantTier}}</span>
          {{#if marketLabel}}<span class="ih-trade-tag">{{marketLabel}}</span>{{/if}}
        </div>
        <div class="ih-trade-wallet">
          <span title="Медь">🟤 {{merchantCoins.copper}}</span>
          <span title="Серебро">⚪ {{merchantCoins.silver}}</span>
          <span title="Золото">🟡 {{merchantCoins.gold}}</span>
          {{#if merchantAfter}}<span class="ih-trade-wallet-after" title="После сделки">→ 🟡{{merchantAfter.gold}} ⚪{{merchantAfter.silver}} 🟤{{merchantAfter.copper}}</span>{{/if}}
        </div>
      </div>
    </div>

    <div class="ih-trade-vs">⇌</div>

    <div class="ih-trade-party right">
      <div class="ih-trade-party-info right">
        <div class="ih-trade-party-name">{{characterName}}</div>
        <div class="ih-trade-wallet right">
          {{#if charAfter}}<span class="ih-trade-wallet-after" title="После сделки">🟡{{charAfter.gold}} ⚪{{charAfter.silver}} 🟤{{charAfter.copper}} →</span>{{/if}}
          <span title="Золото">🟡 {{charCoins.gold}}</span>
          <span title="Серебро">⚪ {{charCoins.silver}}</span>
          <span title="Медь">🟤 {{charCoins.copper}}</span>
        </div>
        <a class="ih-trade-for-other" data-trade-for-other
           title="Торговать от имени другого игрока">
          {{#if characterUuid}}✎ Сменить{{else}}👥 Другой игрок{{/if}}
        </a>
      </div>
      <div class="ih-trade-avatar">
        <img src="{{characterImg}}" alt="{{characterName}}">
      </div>
    </div>
  </div>

  {{!-- ── ТОРГОВЫЙ СТОЛ (две колонки) ── --}}
  <div class="ih-trade-body">

    {{!-- ═══ ЛЕВАЯ: ТОРГОВЕЦ ═══ --}}
    <div class="ih-trade-col">

      {{!-- Инвентарь торговца --}}
      <div class="ih-trade-inv-panel">
        <div class="ih-trade-inv-header">
          <span class="ih-trade-inv-title">Инвентарь торговца</span>
          <input class="ih-trade-search" type="text" placeholder="Поиск..."
                 data-search data-side="right" value="{{searchRight}}">
        </div>

        {{!-- Фильтры --}}
        <div class="ih-trade-filters">
          {{#each merchantCategories}}
          <a class="ih-trade-filter {{#if (eq key ../filterRight)}}is-active{{/if}}"
             data-filter data-side="right" data-category="{{key}}">{{label}}</a>
          {{/each}}
        </div>

        {{!-- Предметы --}}
        <div class="ih-trade-inv-list">
          {{#each merchantItems}}
          <div class="ih-trade-inv-item {{#if multiQty}}has-qty-ctrl{{/if}} ih-has-tooltip"
               data-item-id="{{id}}" data-side="right">
            <img class="ih-trade-inv-icon" src="{{img}}" alt="{{name}}">
            <div class="ih-trade-inv-info">
              <div class="ih-trade-inv-name">{{name}}</div>
              <div class="ih-trade-inv-meta">
                <span class="ih-trade-cat-badge cat-{{category}}">{{categoryLabel}}</span>
                <span class="muted-text" style="font-size:10px">Тир {{tier}}</span>
              </div>
            </div>
            {{!-- Tooltip --}}
            <div class="ih-trade-tooltip">
              <div class="ih-trade-tooltip-header">
                <img src="{{img}}" width="28" height="28" style="border-radius:4px">
                <div>
                  <div style="font-weight:700;font-size:12px">{{name}}</div>
                  <div class="muted-text" style="font-size:10px">Тир {{tier}} · {{categoryLabel}}</div>
                </div>
              </div>
              {{#if tooltipStats}}
              <div class="ih-trade-tooltip-stats">{{tooltipStats}}</div>
              {{/if}}
              {{#if tooltipDesc}}
              <div class="ih-trade-tooltip-desc">{{tooltipDesc}}</div>
              {{/if}}
              <div class="ih-trade-tooltip-price">🪙 {{priceFormatted.val}} {{priceFormatted.currency}}</div>
            </div>
            {{!-- Счётчик --}}
            {{#if multiQty}}
            <div class="ih-trade-qty-ctrl" data-item-id="{{id}}" data-side="right"
                 data-max="{{qty}}">
              <a class="ih-trade-qty-btn" data-qty-dec>−</a>
              <input class="ih-trade-qty-input" type="number"
                     value="1" min="1" max="{{qty}}"
                     data-qty-input data-item-id="{{id}}">
              <a class="ih-trade-qty-btn" data-qty-inc>+</a>
              <span class="ih-trade-qty-max muted-text">/{{qty}}</span>
            </div>
            {{else}}
            <span class="ih-trade-inv-qty-single">×{{qty}}</span>
            {{/if}}
            <div class="ih-trade-inv-price">
              <span class="ih-trade-price-main-val {{priceFormatted.cssClass}}">{{priceFormatted.val}}</span>
              <span class="ih-trade-price-currency">{{priceFormatted.currency}}</span>
            </div>
            <a class="ih-trade-view-btn" data-view-item
               data-item-id="{{id}}" data-side="right"
               title="Открыть карточку предмета">📖</a>
            <a class="ih-trade-add-btn" data-add-to-offer
               data-item-id="{{id}}" data-side="right"
               title="Добавить в предложение">→</a>
          </div>
          {{else}}
          <div class="ih-trade-empty-inv">Нет предметов</div>
          {{/each}}
        </div>
      </div>

      {{!-- Зона предложения торговца --}}
      <div class="ih-trade-offer-zone" data-offer-side="right">
        <div class="ih-trade-offer-title">
          Предложение торговца
          {{#if isGM}}<span class="ih-trade-gm-badge">GM</span>{{/if}}
        </div>

        <div class="ih-trade-offer-items">
          {{#each rightOffer}}
          <div class="ih-trade-offer-item">
            <img class="ih-trade-offer-icon" src="{{icon}}" alt="{{name}}">
            <span class="ih-trade-offer-name">{{name}}</span>
            <span class="ih-trade-offer-qty">×{{qty}}</span>
            {{#if ../isGM}}
            <a class="ih-trade-offer-remove" data-remove-offer
               data-item-id="{{itemId}}" data-side="right" title="Убрать">✕</a>
            {{/if}}
          </div>
          {{/each}}
        </div>

        {{!-- Монеты торговца --}}
        <div class="ih-trade-coins-row">
          {{#each currencies}}
          <div class="ih-trade-coin-field">
            <label>{{label}}</label>
            <input type="number" min="0" class="ih-trade-coin-input"
                   data-coin-input data-side="right" data-currency="{{key}}"
                   value="{{rightValue}}"
                   {{#unless ../isGM}}readonly{{/unless}}>
          </div>
          {{/each}}
        </div>

        <div class="ih-trade-drop-hint">
          {{#if isGM}}Перетащи предмет сюда{{else}}Ожидание GM{{/if}}
        </div>
      </div>

    </div>{{!-- .ih-trade-col left --}}

    {{!-- ═══ ЦЕНТР: БАЛАНС + КНОПКИ ═══ --}}
    <div class="ih-trade-center">

      {{!-- Баланс --}}
      <div class="ih-trade-balance {{balanceClass}}">
        <div class="ih-trade-balance-label">Баланс</div>
        <div class="ih-trade-balance-value">
          {{balanceSign}} {{balanceAbs}} мед.
        </div>
        {{#if balanceCoins.platinum}}<div class="ih-trade-balance-coins">{{balanceCoins.platinum}} пл.</div>{{/if}}
        {{#if balanceCoins.gold}}<div class="ih-trade-balance-coins">{{balanceCoins.gold}} зол.</div>{{/if}}
        {{#if balanceCoins.silver}}<div class="ih-trade-balance-coins">{{balanceCoins.silver}} сер.</div>{{/if}}
        {{#if balanceCoins.copper}}<div class="ih-trade-balance-coins">{{balanceCoins.copper}} мед.</div>{{/if}}
      </div>

      {{!-- Скидка от торговли --}}
      {{#if bargainDiscount}}
      <div class="ih-trade-discount">
        ↓ {{bargainDiscount}}% скидка
      </div>
      {{/if}}

      {{!-- Кнопки действий --}}
      <div class="ih-trade-actions">
        <a class="ih-btn ih-btn-small {{#if bargainUsed}}is-disabled{{/if}}"
           data-bargain title="{{#if bargainUsed}}Уже использовано{{else}}Попытаться снизить цену{{/if}}">
          🗣 Поторговаться
        </a>

        <a class="ih-btn ih-btn-small" data-equalize
           title="Добавить монеты чтобы уравнять предложения">
          ⚖ Уравнять
        </a>

        <a class="ih-btn ih-btn-small ih-btn-danger" data-cancel-trade>
          ✕ Сброс
        </a>
      </div>

      {{!-- Статусы готовности --}}
      <div class="ih-trade-ready-section">
        <a class="ih-trade-ready-btn {{#if leftReady}}is-ready{{/if}}"
           data-ready-left>
          {{#if leftReady}}✓ Готов{{else}}Принять{{/if}}
        </a>
        <a class="ih-trade-ready-btn right {{#if rightReady}}is-ready{{/if}} {{#unless isGM}}is-disabled{{/unless}}"
           data-ready-right>
          {{#if rightReady}}✓ Готов{{else}}Принять (GM){{/if}}
        </a>
      </div>

      {{#if bothReady}}
      <div class="ih-trade-confirm-notice">
        ⏳ Обмен через 3 сек...
      </div>
      {{/if}}

    </div>{{!-- .ih-trade-center --}}

    {{!-- ═══ ПРАВАЯ: ИГРОК ═══ --}}
    <div class="ih-trade-col right">

      {{!-- Зона предложения игрока --}}
      <div class="ih-trade-offer-zone" data-offer-side="left">
        <div class="ih-trade-offer-title">Предложение игрока</div>

        <div class="ih-trade-offer-items">
          {{#each leftOffer}}
          <div class="ih-trade-offer-item">
            <a class="ih-trade-offer-remove" data-remove-offer
               data-item-id="{{itemId}}" data-side="left" title="Убрать">✕</a>
            <span class="ih-trade-offer-qty">×{{qty}}</span>
            <span class="ih-trade-offer-name">{{name}}</span>
            <img class="ih-trade-offer-icon" src="{{icon}}" alt="{{name}}">
          </div>
          {{/each}}
        </div>

        {{!-- Монеты игрока --}}
        <div class="ih-trade-coins-row">
          {{#each currencies}}
          <div class="ih-trade-coin-field">
            <label>{{label}}</label>
            <input type="number" min="0" class="ih-trade-coin-input"
                   data-coin-input data-side="left" data-currency="{{key}}"
                   value="{{leftValue}}">
          </div>
          {{/each}}
        </div>

        <div class="ih-trade-drop-hint">Перетащи предмет сюда</div>
      </div>

      {{!-- Инвентарь игрока --}}
      <div class="ih-trade-inv-panel">
        <div class="ih-trade-inv-header">
          <input class="ih-trade-search" type="text" placeholder="Поиск..."
                 data-search data-side="left" value="{{searchLeft}}">
          <span class="ih-trade-inv-title">Инвентарь игрока</span>
        </div>

        {{!-- Фильтры --}}
        <div class="ih-trade-filters right">
          {{#each charCategories}}
          <a class="ih-trade-filter {{#if (eq key ../filterLeft)}}is-active{{/if}}"
             data-filter data-side="left" data-category="{{key}}">{{label}}</a>
          {{/each}}
        </div>

        {{!-- Предметы --}}
        <div class="ih-trade-inv-list right">
          {{#each charItems}}
          <div class="ih-trade-inv-item {{#if multiQty}}has-qty-ctrl{{/if}} ih-has-tooltip"
               data-item-id="{{id}}" data-side="left">
            <img class="ih-trade-inv-icon" src="{{img}}" alt="{{name}}">
            <div class="ih-trade-inv-info">
              <div class="ih-trade-inv-name">{{name}}</div>
              <div class="ih-trade-inv-meta">
                <span class="ih-trade-cat-badge cat-{{category}}">{{categoryLabel}}</span>
                <span class="muted-text" style="font-size:10px">Тир {{tier}}</span>
              </div>
            </div>
            {{!-- Tooltip --}}
            <div class="ih-trade-tooltip">
              <div class="ih-trade-tooltip-header">
                <img src="{{img}}" width="28" height="28" style="border-radius:4px">
                <div>
                  <div style="font-weight:700;font-size:12px">{{name}}</div>
                  <div class="muted-text" style="font-size:10px">Тир {{tier}} · {{categoryLabel}}</div>
                </div>
              </div>
              {{#if tooltipStats}}
              <div class="ih-trade-tooltip-stats">{{tooltipStats}}</div>
              {{/if}}
              {{#if tooltipDesc}}
              <div class="ih-trade-tooltip-desc">{{tooltipDesc}}</div>
              {{/if}}
              <div class="ih-trade-tooltip-price">🪙 {{priceFormatted.val}} {{priceFormatted.currency}}</div>
            </div>
            {{!-- Счётчик --}}
            {{#if multiQty}}
            <div class="ih-trade-qty-ctrl" data-item-id="{{id}}" data-side="left"
                 data-max="{{qty}}">
              <a class="ih-trade-qty-btn" data-qty-dec>−</a>
              <input class="ih-trade-qty-input" type="number"
                     value="1" min="1" max="{{qty}}"
                     data-qty-input data-item-id="{{id}}">
              <a class="ih-trade-qty-btn" data-qty-inc>+</a>
              <span class="ih-trade-qty-max muted-text">/{{qty}}</span>
            </div>
            {{else}}
            <span class="ih-trade-inv-qty-single">×{{qty}}</span>
            {{/if}}
            <div class="ih-trade-inv-price">
              <span class="ih-trade-price-main-val {{priceFormatted.cssClass}}">{{priceFormatted.val}}</span>
              <span class="ih-trade-price-currency">{{priceFormatted.currency}}</span>
            </div>
            <a class="ih-trade-view-btn" data-view-item
               data-item-id="{{id}}" data-side="left"
               title="Открыть карточку">📖</a>
            <a class="ih-trade-add-btn" data-add-to-offer
               data-item-id="{{id}}" data-side="left"
               title="Добавить в предложение">→</a>
          </div>
          {{else}}
          <div class="ih-trade-empty-inv">Нет предметов</div>
          {{/each}}
        </div>
      </div>

    </div>{{!-- .ih-trade-col right --}}
  </div>{{!-- .ih-trade-body --}}

</div>{{!-- .ih-trade-app --}}
