<div class="ih-travel-app">

  {{!-- Выбор группы --}}
  <div class="ih-travel-section">
    <div class="ih-travel-section-title">Группа</div>
    <div class="ih-travel-group-row">
      <div class="ih-travel-group-dot" style="background:{{groupColor}}"></div>
      <select class="ih-travel-group-select" data-group-select>
        <option value="">Все персонажи игроков</option>
        {{#each groups}}
        <option value="{{id}}" {{#if (eq id ../groupId)}}selected{{/if}}>
          {{label}} ({{#if isActive}}активна{{else}}неактивна{{/if}})
        </option>
        {{/each}}
      </select>
    </div>

    {{!-- Другие группы --}}
    {{#if hasOtherGroups}}
    <div class="ih-travel-other-groups">
      {{#each otherGroups}}
      <div class="ih-travel-other-group">
        <div class="ih-travel-group-dot" style="background:{{color}}"></div>
        <span>{{label}}</span>
        {{#if location}}<span class="muted-text">@ {{location}}</span>{{/if}}
        <span class="muted-text">{{localHours}}ч · {{memberCount}} чел.</span>
      </div>
      {{/each}}
    </div>
    {{/if}}
  </div>

  {{!-- Активность --}}
  <div class="ih-travel-section">
    <div class="ih-travel-section-title">
      Активность
      <a class="ih-travel-camp-toggle {{#if campMode}}is-active{{/if}}" data-toggle-camp>
        🏕 {{#if campMode}}Привал (выкл){{else}}Привал (инд.){{/if}}
      </a>
    </div>
    {{#unless campMode}}
    <div class="ih-travel-activities">
      {{#each activities}}
      <a class="ih-travel-act {{#if (eq key ../activity)}}is-active{{/if}}"
         data-activity="{{key}}">{{label}}</a>
      {{/each}}
    </div>
    {{/unless}}
  </div>

  {{!-- Время --}}
  <div class="ih-travel-section">
    <div class="ih-travel-section-title">
      Время
      <span class="ih-travel-hours-display"><b data-hours-label>{{hours}}</b>ч <b data-mins-label>{{mins}}</b>м</span>
    </div>
    {{!-- Часы --}}
    <div class="ih-wa-set-row" style="margin-bottom:4px">
      <label class="ih-wa-set-label">Ч</label>
      <div class="ih-wa-stepper">
        <a class="ih-wa-step-btn" data-step-hours="-1">−</a>
        <input class="ih-wa-set-input" data-hours-direct type="number" min="0" max="72" value="{{hours}}">
        <a class="ih-wa-step-btn" data-step-hours="1">+</a>
      </div>
    </div>
    {{!-- Минуты --}}
    <div class="ih-wa-set-row" style="margin-bottom:6px">
      <label class="ih-wa-set-label">М</label>
      <div class="ih-wa-stepper">
        <a class="ih-wa-step-btn" data-step-mins="-10">−</a>
        <input class="ih-wa-set-input" data-mins-direct type="number" min="0" max="59" value="{{mins}}">
        <a class="ih-wa-step-btn" data-step-mins="10">+</a>
      </div>
    </div>
    <div class="ih-travel-presets">
      <a class="ih-btn ih-btn-small" data-preset-hours="0" data-preset-mins="10">10м</a>
      <a class="ih-btn ih-btn-small" data-preset-hours="0" data-preset-mins="30">30м</a>
      <a class="ih-btn ih-btn-small" data-preset-hours="1" data-preset-mins="0">1ч</a>
      <a class="ih-btn ih-btn-small" data-preset-hours="4" data-preset-mins="0">4ч</a>
      <a class="ih-btn ih-btn-small" data-preset-hours="8" data-preset-mins="0">8ч</a>
      <a class="ih-btn ih-btn-small" data-preset-hours="24" data-preset-mins="0">Сутки</a>
    </div>
  </div>

  {{!-- Превью --}}
  {{#if hasMembers}}
  <div class="ih-travel-section">
    <div class="ih-travel-section-title">Персонажи ({{preview.length}})</div>
    <div class="ih-travel-chars">
      {{#each preview}}
      <div class="ih-travel-char {{#if hasWarning}}has-warning{{/if}}">
        <img class="ih-travel-char-img" src="{{img}}" alt="{{name}}">
        <div class="ih-travel-char-info">
          <div class="ih-travel-char-name">
            {{name}}
            {{#if ../campMode}}
            <span class="ih-travel-char-act-label">· {{activityLabel}}</span>
            {{/if}}
          </div>
          {{#if ../campMode}}
          <div class="ih-travel-camp-acts">
            {{#each ../activities}}
            <a class="ih-btn ih-btn-small {{#if (eq ../../activityKey key)}}ih-btn-primary{{/if}}"
               style="font-size:9px;padding:1px 5px"
               data-camp-activity="{{key}}" data-actor-id="{{../../actorId}}">{{label}}</a>
            {{/each}}
          </div>
          {{/if}}
          <div class="ih-travel-char-bars">
            <div class="ih-travel-bar-row" title="Сытость −{{satCost}}">
              <span>🍖</span>
              <div class="ih-travel-bar-track">
                <div class="ih-travel-bar-fill" style="width:{{satPct}}%"></div>
              </div>
              <span class="ih-travel-bar-delta neg">−{{satCost}}</span>
            </div>
            <div class="ih-travel-bar-row" title="Жажда −{{hydCost}}">
              <span>💧</span>
              <div class="ih-travel-bar-track">
                <div class="ih-travel-bar-fill water" style="width:{{hydPct}}%"></div>
              </div>
              <span class="ih-travel-bar-delta neg">−{{hydCost}}</span>
            </div>
            {{!-- Энергия: итоговое изменение --}}
            {{#unless enFull}}
            <div class="ih-travel-bar-row" title="⚡ {{enVal}}/{{enCurMax}} → {{newEn}}/{{newEnMax}}">
              <span>⚡</span>
              <div class="ih-travel-bar-track">
                <div class="ih-travel-bar-fill energy" style="width:{{enPct}}%"></div>
              </div>
              {{#if enCost}}
                <span class="ih-travel-bar-delta neg">−{{enCostFmt}}</span>
              {{else if enNetDelta}}
                {{#if (gt enNetDelta 0)}}
                  <span class="ih-travel-bar-delta pos">тек. +{{enNetDelta}}</span>
                {{else}}
                  <span class="ih-travel-bar-delta neg">тек. {{enNetDelta}}</span>
                {{/if}}
              {{else}}
                <span class="ih-travel-bar-delta">—</span>
              {{/if}}
            </div>
            {{/unless}}
            {{#if maxDelta}}
            <div class="ih-travel-bar-row" title="⚡ Макс: {{enCurMax}} → {{newEnMax}}">
              <span>⬆⚡</span>
              <div class="ih-travel-bar-track">
                <div class="ih-travel-bar-fill energy-max" style="width:{{enPct}}%"></div>
              </div>
              <span class="ih-travel-bar-delta pos">макс. +{{maxDelta}}</span>
            </div>
            {{/if}}
            {{!-- Мана --}}
            {{#if mnFull}}
            <div class="ih-travel-bar-row">
              <span>✦</span>
              <div class="ih-travel-bar-track">
                <div class="ih-travel-bar-fill mana" style="width:100%"></div>
              </div>
              <span class="ih-travel-bar-delta muted-text">полная</span>
            </div>
            {{else if mnDelta}}
            <div class="ih-travel-bar-row" title="Мана {{mnVal}} → {{newMn}}">
              <span>✦</span>
              <div class="ih-travel-bar-track">
                <div class="ih-travel-bar-fill mana" style="width:{{enPct}}%"></div>
              </div>
              {{#if (gt mnDelta 0)}}
                <span class="ih-travel-bar-delta pos">+{{mnDelta}}</span>
              {{else}}
                <span class="ih-travel-bar-delta neg">{{mnDelta}}</span>
              {{/if}}
            </div>
            {{/if}}
          </div>
          {{#if hungerLabel}}<div class="ih-travel-warn">{{hungerLabel}}</div>{{/if}}
          {{#if thirstLabel}}<div class="ih-travel-warn blue">{{thirstLabel}}</div>{{/if}}
        </div>
      </div>
      {{/each}}
    </div>
  </div>
  {{else}}
  <div class="ih-travel-empty">Нет персонажей в группе</div>
  {{/if}}

  {{!-- Кнопки --}}
  <div class="ih-travel-actions">
    {{#if campMode}}
    {{!-- Режим привала: одна кнопка применяет индивидуальные активности --}}
    <a class="ih-btn ih-btn-primary" style="flex:1;justify-content:center" data-apply-rest>
      🏕 Привал {{hours}}ч {{mins}}м
    </a>
    {{else}}
    {{!-- Обычный режим: применить выбранную активность --}}
    <a class="ih-btn ih-btn-primary" style="flex:1;justify-content:center" data-apply-time>
      ⏳ Применить {{hours}}ч {{mins}}м
    </a>
    {{/if}}
  </div>

</div>
