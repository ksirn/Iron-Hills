{{!-- Iron Hills — AoE attack/spell summary chat card.
     Контекст: { label, icon, totalCount, hitCount, alliesSpared, results:[{name, hit, roll, threshold, damage, armor, condition}] } --}}

<div style="padding:6px;font-family:var(--font-primary)">
  {{icon}} <b>{{label}}</b><br>
  {{localize "IRONHILLS.Chat.Aoe.TargetCount"}}: <b>{{totalCount}}</b> / {{localize "IRONHILLS.Chat.Aoe.HitCount"}}: <b>{{hitCount}}</b>
  {{#if (gt alliesSpared 0)}}
    <br><span style="color:#7d9aff;">{{localize "IRONHILLS.Chat.Aoe.AlliesSpared"}}: {{alliesSpared}}</span>
  {{/if}}
  <br>
  {{#each results}}
    {{#if this.hit}}
      ✓ {{this.name}}: <b>{{this.damage}}</b> {{localize "IRONHILLS.Chat.Aoe.LineHit"}} ({{localize "IRONHILLS.Chat.Aoe.RollSlash"}} {{this.roll}}/{{this.threshold}}{{#if (gt this.armor 0)}}, броня −{{this.armor}}{{/if}}{{#if this.condition}}, {{this.condition}}{{/if}})
    {{else}}
      ✗ {{this.name}}: {{localize "IRONHILLS.Chat.Aoe.LineMiss"}} ({{localize "IRONHILLS.Chat.Aoe.RollSlash"}} {{this.roll}}/{{this.threshold}})
    {{/if}}
    {{#unless @last}}<br>{{/unless}}
  {{/each}}
</div>
