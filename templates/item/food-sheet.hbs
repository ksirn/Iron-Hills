<form class="iron-hills-sheet">
  <header class="sheet-header">
    <h1><input type="text" name="name" value="{{item.name}}"></h1>
  </header>

  <section class="sheet-body">
    <div class="grid two-col">
      <label>Тир
        <input type="number" name="system.tier" value="{{system.tier}}">
      </label>

      <label>Качество
        <select name="system.quality">
          <option value="common" {{#if (eq system.quality "common")}}selected{{/if}}>Обычное</option>
          <option value="fine" {{#if (eq system.quality "fine")}}selected{{/if}}>Хорошее</option>
          <option value="masterwork" {{#if (eq system.quality "masterwork")}}selected{{/if}}>Мастерское</option>
          <option value="legendary" {{#if (eq system.quality "legendary")}}selected{{/if}}>Легендарное</option>
        </select>
      </label>

      <label>Вес
        <input type="number" name="system.weight" value="{{system.weight}}">
      </label>

      <label>Количество
        <input type="number" name="system.quantity" value="{{system.quantity}}">
      </label>

      <label>Сытость
        <input type="number" name="system.satiety" value="{{system.satiety}}">
      </label>

      <label>Жажда
        <input type="number" name="system.hydration" value="{{system.hydration}}">
      </label>
    </div>
  </section>
</form>