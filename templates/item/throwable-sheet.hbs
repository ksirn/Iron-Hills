<form class="iron-hills-sheet">
  <header class="sheet-header">
    <h1><input type="text" name="name" value="{{item.name}}"></h1>
  </header>

  <section class="sheet-body">
    <div class="grid two-col">
      <label>Тир <input type="number" name="system.tier" value="{{system.tier}}"></label>
      <label>Качество
        <select name="system.quality">
          <option value="common" {{#if (eq system.quality "common")}}selected{{/if}}>Обычное</option>
          <option value="fine" {{#if (eq system.quality "fine")}}selected{{/if}}>Хорошее</option>
          <option value="masterwork" {{#if (eq system.quality "masterwork")}}selected{{/if}}>Мастерское</option>
          <option value="legendary" {{#if (eq system.quality "legendary")}}selected{{/if}}>Легендарное</option>
        </select>
      </label>
      <label>Вес <input type="number" name="system.weight" value="{{system.weight}}"></label>
      <label>Количество <input type="number" name="system.quantity" value="{{system.quantity}}"></label>
      <label>Эффект
        <select name="system.effectType">
          <option value="damage" {{#if (eq system.effectType "damage")}}selected{{/if}}>Урон</option>
        </select>
      </label>
      <label>Тип урона
        <select name="system.damageType">
          <option value="physical" {{#if (eq system.damageType "physical")}}selected{{/if}}>Физический</option>
          <option value="magical" {{#if (eq system.damageType "magical")}}selected{{/if}}>Магический</option>
        </select>
      </label>
      <label>Сила <input type="number" name="system.power" value="{{system.power}}"></label>
      <label>Энергия <input type="number" name="system.energyCost" value="{{system.energyCost}}"></label>
      <label>Яд <input type="number" name="system.appliesPoison" value="{{system.appliesPoison}}"></label>
      <label>Горение <input type="number" name="system.appliesBurning" value="{{system.appliesBurning}}"></label>
      <label>Часть тела
        <select name="system.targetPart">
          <option value="head" {{#if (eq system.targetPart "head")}}selected{{/if}}>Голова</option>
          <option value="torso" {{#if (eq system.targetPart "torso")}}selected{{/if}}>Торс</option>
          <option value="leftArm" {{#if (eq system.targetPart "leftArm")}}selected{{/if}}>Левая рука</option>
          <option value="rightArm" {{#if (eq system.targetPart "rightArm")}}selected{{/if}}>Правая рука</option>
          <option value="leftLeg" {{#if (eq system.targetPart "leftLeg")}}selected{{/if}}>Левая нога</option>
          <option value="rightLeg" {{#if (eq system.targetPart "rightLeg")}}selected{{/if}}>Правая нога</option>
        </select>
      </label>
    </div>
  </section>
</form>